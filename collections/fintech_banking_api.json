{
  "info": {
    "name": "Fintech Banking API Tests",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "API test collection simulating core banking scenarios — Auth, Fund Transfer, Loan Application.\nBase URL: reqres.in (public mock API)\nAuthor: Htuu Will Oo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login - Valid Credentials",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"eve.holt@reqres.in\",\n  \"password\": \"cityslicka\"\n}"
            },
            "url": {
              "raw": "https://reqres.in/api/login",
              "protocol": "https",
              "host": ["reqres", "in"],
              "path": ["api", "login"]
            },
            "description": "Login with correct credentials. Expect 200 and a token in response."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Check the request went through fine",
                  "pm.test(\"Status is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Make sure we actually got a token back",
                  "pm.test(\"Response has token\", function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body).to.have.property(\"token\");",
                  "    pm.expect(body.token).to.be.a(\"string\");",
                  "    pm.expect(body.token.length).to.be.above(0);",
                  "});",
                  "",
                  "// Save the token so other requests can use it",
                  "var body = pm.response.json();",
                  "pm.environment.set(\"auth_token\", body.token);",
                  "",
                  "pm.test(\"Response time is under 3 seconds\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Wrong Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"eve.holt@reqres.in\",\n  \"password\": \"wrongpassword123\"\n}"
            },
            "url": {
              "raw": "https://reqres.in/api/login",
              "protocol": "https",
              "host": ["reqres", "in"],
              "path": ["api", "login"]
            },
            "description": "Negative test — wrong password should be rejected. In banking apps this is critical because too many failed attempts should trigger account lock."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Wrong password must be rejected — not silently accepted",
                  "pm.test(\"Status is 400 Bad Request\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "// Error message must exist so the user knows what went wrong",
                  "pm.test(\"Response has error message\", function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body).to.have.property(\"error\");",
                  "    pm.expect(body.error).to.be.a(\"string\");",
                  "});",
                  "",
                  "// Make sure no token was returned with wrong password",
                  "pm.test(\"No token returned on failed login\", function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body).to.not.have.property(\"token\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Empty Email Field",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"\",\n  \"password\": \"cityslicka\"\n}"
            },
            "url": {
              "raw": "https://reqres.in/api/login",
              "protocol": "https",
              "host": ["reqres", "in"],
              "path": ["api", "login"]
            },
            "description": "Negative test — empty email field. The API should reject this, not crash or return 500."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Empty required field should be rejected cleanly",
                  "pm.test(\"Status is 400 Bad Request\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test(\"Error message mentions missing field\", function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body).to.have.property(\"error\");",
                  "});",
                  "",
                  "// The API should not return a 500 — that would mean it crashed",
                  "pm.test(\"No server error\", function () {",
                  "    pm.response.to.not.have.status(500);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Fund Transfer",
      "item": [
        {
          "name": "Transfer - Create Successful Transfer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_account\": \"ACC-001-SAVING\",\n  \"to_account\": \"ACC-002-CURRENT\",\n  \"amount\": 50000,\n  \"currency\": \"THB\",\n  \"description\": \"Monthly rent payment\",\n  \"reference\": \"TXN-2024-001\"\n}"
            },
            "url": {
              "raw": "https://reqres.in/api/users",
              "protocol": "https",
              "host": ["reqres", "in"],
              "path": ["api", "users"]
            },
            "description": "Positive test — valid transfer between two accounts. Using POST /users as a mock for transfer creation since reqres.in simulates a create operation."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Transfer created successfully",
                  "pm.test(\"Status is 201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "// Response should echo back what we sent",
                  "pm.test(\"Response contains transfer details\", function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body).to.have.property(\"from_account\");",
                  "    pm.expect(body.from_account).to.equal(\"ACC-001-SAVING\");",
                  "    pm.expect(body.amount).to.equal(50000);",
                  "});",
                  "",
                  "// Save the reference for the duplicate test below",
                  "pm.environment.set(\"last_txn_reference\", \"TXN-2024-001\");",
                  "",
                  "pm.test(\"Amount is a number not a string\", function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body.amount).to.be.a(\"number\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Transfer - Duplicate Transaction",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_account\": \"ACC-001-SAVING\",\n  \"to_account\": \"ACC-002-CURRENT\",\n  \"amount\": 50000,\n  \"currency\": \"THB\",\n  \"description\": \"Monthly rent payment\",\n  \"reference\": \"TXN-2024-001\"\n}"
            },
            "url": {
              "raw": "https://reqres.in/api/users",
              "protocol": "https",
              "host": ["reqres", "in"],
              "path": ["api", "users"]
            },
            "description": "Negative test — same reference number as the previous request. In real banking systems, duplicate references must be rejected to prevent double charges. This is one of the most critical tests in any payment API."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// NOTE: reqres.in always returns 201 — in a real banking API",
                  "// this should return 409 Conflict for a duplicate reference.",
                  "// This test documents what the expected behavior should be.",
                  "",
                  "pm.test(\"Request was processed (mock API)\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                  "});",
                  "",
                  "// In production: duplicate reference must return 409",
                  "pm.test(\"[Expected in production] Duplicate reference rejected with 409\", function () {",
                  "    // This test is intentionally documented as a known gap in mock testing.",
                  "    // Real banking API should return 409 Conflict with message:",
                  "    // { \"error\": \"Transaction reference TXN-2024-001 already exists\" }",
                  "    pm.expect(true).to.be.true; // placeholder",
                  "});",
                  "",
                  "pm.test(\"Response time is acceptable\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Transfer - Amount Below Minimum (Boundary)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_account\": \"ACC-001-SAVING\",\n  \"to_account\": \"ACC-002-CURRENT\",\n  \"amount\": 0.5,\n  \"currency\": \"THB\",\n  \"description\": \"Test below minimum\",\n  \"reference\": \"TXN-2024-002\"\n}"
            },
            "url": {
              "raw": "https://reqres.in/api/users",
              "protocol": "https",
              "host": ["reqres", "in"],
              "path": ["api", "users"]
            },
            "description": "Boundary test — amount of 0.5 THB is below the minimum transfer limit. Most banks set a minimum (usually 1.00). The API should reject this."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Boundary test: amount below minimum should be rejected",
                  "// Real banking API should return 422 Unprocessable Entity",
                  "",
                  "pm.test(\"Request was processed by mock API\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 400, 422]);",
                  "});",
                  "",
                  "// Document the expected production behavior",
                  "pm.test(\"[Expected in production] Amount 0.5 rejected — below minimum\", function () {",
                  "    // Expected response: 422",
                  "    // { \"error\": \"Amount must be at least 1.00 THB\" }",
                  "    pm.expect(true).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"Response body is valid JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Transfer - Amount Above Maximum (Boundary)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_account\": \"ACC-001-SAVING\",\n  \"to_account\": \"ACC-002-CURRENT\",\n  \"amount\": 99999999999,\n  \"currency\": \"THB\",\n  \"description\": \"Test above maximum\",\n  \"reference\": \"TXN-2024-003\"\n}"
            },
            "url": {
              "raw": "https://reqres.in/api/users",
              "protocol": "https",
              "host": ["reqres", "in"],
              "path": ["api", "users"]
            },
            "description": "Boundary test — extremely large amount. The API should validate against a maximum transfer limit and reject this, not overflow or crash."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Very large amount should be caught by validation",
                  "pm.test(\"Request processed without server crash\", function () {",
                  "    pm.response.to.not.have.status(500);",
                  "});",
                  "",
                  "pm.test(\"Response body is valid JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "// Document expected production behavior",
                  "pm.test(\"[Expected in production] Amount rejected — exceeds daily limit\", function () {",
                  "    // Expected: 422",
                  "    // { \"error\": \"Amount exceeds maximum transfer limit\" }",
                  "    pm.expect(true).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Loan Application",
      "item": [
        {
          "name": "Loan - Submit Valid Application",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"applicant_name\": \"Htuu Will Oo\",\n  \"account_number\": \"ACC-001-SAVING\",\n  \"loan_amount\": 500000,\n  \"loan_term_months\": 12,\n  \"purpose\": \"Home renovation\",\n  \"monthly_income\": 80000\n}"
            },
            "url": {
              "raw": "https://reqres.in/api/users",
              "protocol": "https",
              "host": ["reqres", "in"],
              "path": ["api", "users"]
            },
            "description": "Positive test — submit a complete and valid loan application. All required fields are present."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Application data is returned\", function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body).to.have.property(\"applicant_name\");",
                  "    pm.expect(body.loan_amount).to.equal(500000);",
                  "});",
                  "",
                  "pm.test(\"Loan term is a number\", function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body.loan_term_months).to.be.a(\"number\");",
                  "});",
                  "",
                  "pm.test(\"Response time is under 3 seconds\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Loan - Missing Required Field (loan_amount)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"applicant_name\": \"Htuu Will Oo\",\n  \"account_number\": \"ACC-001-SAVING\",\n  \"loan_term_months\": 12,\n  \"purpose\": \"Home renovation\",\n  \"monthly_income\": 80000\n}"
            },
            "url": {
              "raw": "https://reqres.in/api/users",
              "protocol": "https",
              "host": ["reqres", "in"],
              "path": ["api", "users"]
            },
            "description": "Negative test — loan_amount field is missing. The API must reject incomplete applications. In real systems, missing this field could create a loan record with 0 amount — a serious bug."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Missing loan amount must not be silently accepted",
                  "pm.test(\"Request processed by mock API\", function () {",
                  "    pm.response.to.not.have.status(500);",
                  "});",
                  "",
                  "pm.test(\"Response is valid JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "// Document expected production behavior",
                  "pm.test(\"[Expected in production] Missing loan_amount rejected with 400\", function () {",
                  "    // Expected: 400 Bad Request",
                  "    // { \"error\": \"loan_amount is required\" }",
                  "    // This prevents a loan record being created with amount = null or 0",
                  "    pm.expect(true).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Loan - Invalid Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer invalid_token_xyz_123" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"applicant_name\": \"Htuu Will Oo\",\n  \"account_number\": \"ACC-001-SAVING\",\n  \"loan_amount\": 500000,\n  \"loan_term_months\": 12,\n  \"purpose\": \"Home renovation\",\n  \"monthly_income\": 80000\n}"
            },
            "url": {
              "raw": "https://reqres.in/api/users",
              "protocol": "https",
              "host": ["reqres", "in"],
              "path": ["api", "users"]
            },
            "description": "Negative test — expired or invalid auth token. This is a security test. If the API accepts requests with bad tokens, any unauthenticated user could submit loan applications."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Invalid token must be rejected — this is a security requirement",
                  "pm.test(\"Response does not crash the server\", function () {",
                  "    pm.response.to.not.have.status(500);",
                  "});",
                  "",
                  "pm.test(\"Response is valid JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "// Document expected production behavior",
                  "pm.test(\"[Expected in production] Invalid token rejected with 401\", function () {",
                  "    // Expected: 401 Unauthorized",
                  "    // { \"error\": \"Invalid or expired token\" }",
                  "    // If this returns 201, the API has a serious authentication gap",
                  "    pm.expect(true).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "auth_token",
      "value": "",
      "description": "Set automatically after Login - Valid Credentials runs"
    },
    {
      "key": "last_txn_reference",
      "value": "",
      "description": "Set automatically after first transfer runs"
    }
  ]
}
